@model List<TheDigitalCookbook.Recipe>
@{
    ViewData["Title"] = "Recipe Search Report";
}

<div class="container mt-5">
    <h1 class="mb-4">Recipe Search Report</h1>

    <form asp-controller="Recipe" asp-action="Report" method="get" class="d-flex gap-2 mb-4">
        <input type="text" name="query" class="form-control" placeholder="Search recipe name..." value="@ViewBag.Query" />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-controller="Recipe" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>

    @if (!string.IsNullOrWhiteSpace((string)ViewBag.Query))
    {
        <p>Results for <strong>@ViewBag.Query</strong></p>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="list-group">
            @foreach (var recipe in Model)
            {
                <div class="list-group-item border border-2 border-secondary rounded mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-1">@recipe.Name</h5>
                        <small>@recipe.CreatedAt.ToLocalTime().ToString("g")</small>
                    </div>
                    <p class="mb-0">@recipe.Category</p>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No recipes matched your search.</p>
    }
</div>