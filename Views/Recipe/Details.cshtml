@model TheDigitalCookbook.Recipe

@{
    ViewData["Title"] = "Recipe Details";
}

<div class="container mt-5">
    <h1 class="mb-4">Recipe Details</h1>

    <form asp-action="Details" asp-controller="Recipe" method="post">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label" for="name">Name</label>
            <input class="form-control" type="text" id="name" name="name" value="@Model.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="category">Category</label>
            <input class="form-control" type="text" id="category" name="category" value="@Model.Category" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="ingredients">Ingredients</label>
            <textarea class="form-control" id="ingredients" name="ingredients" rows="5">@string.Join(Environment.NewLine, Model.Ingredients)</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label" for="instructions">Instructions</label>
            <textarea class="form-control" id="instructions" name="instructions" rows="6">@string.Join(Environment.NewLine, Model.Instructions)</textarea>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label" for="prepTime">Prep Time</label>
                <input class="form-control" type="time" id="prepTime" name="prepTime" value="@Model.PrepTime.ToString(@"hh\:mm")" />
            </div>

            <div class="col-md-4 mb-3">
                <label class="form-label" for="cookTime">Cook Time</label>
                <input class="form-control" type="time" id="cookTime" name="cookTime" value="@Model.CookTime.ToString(@"hh\:mm")" />
            </div>

            <div class="col-md-4 mb-3">
                <label class="form-label" for="url">URL</label>
                <input class="form-control" type="url" id="url" name="url" value="@Model.URL" />
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-outline-secondary btn-lg" 
                    onclick="window.location.href='@Url.Action("Index", "Recipe")'">
                Cancel
            </button>
        </div>
    </form> <hr class="my-4" />

    <form action="@Url.Action("Delete", "Recipe", new { id = Model.Id })" method="post" onsubmit="return confirm('Delete this recipe?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
    </form>
</div>