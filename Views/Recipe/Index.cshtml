@model List<TheDigitalCookbook.Recipe>
@{
    ViewData["Title"] = $"{@ViewBag.Username}'s Recipes";
}

@if (TempData["RecipeAdded"] != null)
{
    <script>
        alert('@TempData["RecipeAdded"]');
    </script>
}

@if (TempData["RecipeDeleted"] != null)
{
    <script>
        alert('@TempData["RecipeDeleted"]');
    </script>   
}


<div class="container mt-5">
    <h1 class="mb-4">@ViewBag.Username's Recipes</h1>
    <button type="button" 
            class="btn btn-outline-secondary btn-lg"
            onclick="window.location.href='@Url.Action("Create", "Recipe")'">
        Add Recipe
    </button>

    <button type="button" 
            class="btn btn-outline-secondary btn-lg"
            onclick="window.location.href='@Url.Action("Report", "Recipe")'">
        Search
    </button>
    

    <p>Welcome back, @ViewBag.Username!</p>
    <p>Here are your recipes!</p>
    
    @if (Model != null && Model.Count() > 0)
    {
        <div class="list-group">
            @foreach (var recipe in Model)
            {
                <div class="list-group-item border border-2 border-secondary rounded mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-1" id="recipe-name">@recipe.Name</h5>
                        
                        <div class="btn-group">
                            <button type="button" 
                                    class="btn btn-outline-secondary btn-lg"
                                    onclick="window.location.href='@Url.Action("Details", "Recipe", new {id = recipe.Id})'">
                                View/Edit
                            </button>
                        </div>
                        @* add delete button *@
                        
                        <small>Date Added @recipe.CreatedAt.ToLocalTime().ToString("g")</small>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">You haven't added any recipes yet.</p>
    }
</div>
